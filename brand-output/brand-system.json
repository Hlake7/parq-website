      "heading": "General Sans Semibold, h2, Ink (#1A1F2E)",
      "body": "Inter Regular, body, Ink (#1A1F2E)",
      "secondary_text": "Inter Regular, body_small, Slate (#4A5167)"
    },
    "card_components": {
      "background": "Mist (#E8EAF0)",
      "heading": "General Sans Medium, h4, Ink (#1A1F2E)",
