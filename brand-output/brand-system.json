{
  "brand": "Parq AI",
  "version": "1.0",
  "date": "2026-02-19",
  "description": "Assembled brand system combining strategy, color, typography, and logo specifications into a unified design system for production use.",

  "brand_summary": {
    "positioning": "AI-powered autonomous parking compliance platform for property managers, municipalities, and commercial real estate operators",
    "archetype": "The Sentinel — vigilant, precise, always-on protector of property value",
    "aesthetic": "Calm authority. Structured, minimal, and data-informed. References Palantir, Linear, Vercel, Stripe.",
    "primary_tagline": "Every spot. Every hour. Every time.",
    "color_identity": "Deep navy (#0A1628) anchors authority; electric teal (#00C2B7) signals intelligent precision",
    "type_identity": "General Sans headlines, Inter body, JetBrains Mono data — geometric confidence, screen-optimized readability, technical credibility",
    "logo_identity": "Coordinate Grid — 3x3 grid with teal detection node, representing the spatial mapping technology"
  },

  "cross_references": {
    "hero_sections": {
      "background": "Parq Navy (#0A1628)",
